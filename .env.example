# 네이버 검색 API (지역검색) — https://developers.naver.com
# 가게 식별·주소·좌표·전화번호 수집용 (하루 25,000회, 개인 서비스엔 사실상 무료)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 게시 대상 네이버 블로그 ID (예: blog.naver.com/<여기>) — 앱 첫 실행 시 받아 저장
NAVER_BLOG_ID=

# 텍스트/비전 LLM API 키 — 쓰는 것만 채우면 됨 (모델 선택은 config/models.yaml / 모델 탭)
ANTHROPIC_API_KEY=       # Claude
OPENAI_API_KEY=          # GPT
GEMINI_API_KEY=          # Gemini (사진 분석·자동 캡션 기본)
NVIDIA_API_KEY=          # NVIDIA build.nvidia.com (🎨 AI 썸네일 — Qwen-Image-Edit)
